

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url eka methana naha, eka config eke thiyenawa (Kalin haduwa wage)
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  PATIENT
  STAFF
  RECEPTIONIST
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  role          Role     @default(PATIENT)
  password  String?  // Password එක මුලින්ම නැති නිසා optional කරන්න
  isActive  Boolean  @default(false) // 👈 මේක අනිවාර්යයි
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships - එක් User කෙනෙකුට තිබිය හැක්කේ එක Profile එකක් පමණි
  doctorProfile  Doctor?
  staffProfile   StaffProfile?
}

model StaffProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  phone       String?
  address1    String?
  address2    String?
  city        String?
  designation String   // Nurse, Receptionist, Pharmacist ලෙස මෙතනට වැටේ
  createdAt   DateTime @default(now())
}

model Doctor {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName      String
  lastName       String
  // 2. පැරණි specialization String එක වෙනුවට Category එකට link කරමු
  categoryId     String
  category       DoctorCategory @relation(fields: [categoryId], references: [id])
  licenseNumber  String   @unique
  phone          String?

  // Address Info
  address1       String?
  address2       String?
  city           String?

  // Professional & Education Info
  education      String    // MBBS, MD, etc.
  university     String?   // Graduated University
  workingHospital String?  // Currently working hospital

  appointments   Appointment[]
  schedules       DoctorSchedule[] // දොස්තරගේ වැඩ කරන දින දර්ශනය
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DoctorSchedule {
  id          String   @id @default(uuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  workingDate DateTime // වැඩ කරන දිනය
  startTime   String   // උදා: "08:00 AM"
  endTime     String   // උදා: "12:00 PM"
  status      String   @default("Available") // Available, Not Available (Leave)
  maxPatients Int      @default(20) // දොස්තර බලන උපරිම රෝගීන් ගණන
  bookedCount Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DoctorCategory {
  id      String   @id @default(uuid())
  name    String   @unique // උදා: Cardiologist, Dentist, Neurologist
  doctors Doctor[] // මෙම category එකට අදාළ වන දොස්තරලා ලැයිස්තුව
}


model Patient {
  id        String   @id @default(uuid())
  fullName  String
  phone     String?
  nic       String   @unique
  appointments Appointment[]
}

model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  scheduledAt DateTime
  status      String   @default("PENDING")
  priority    Int      @default(1)

  medicalRecords MedicalRecord[]
}

model MedicalRecord {
  id              String         @id @default(uuid())
  appointmentId   String         @unique // එක appointment එකකට තියෙන්නේ එක record එකයි
  appointment     Appointment    @relation(fields: [appointmentId], references: [id])

  patientName     String
  guardianName    String?        // දරුවෙක් නම් දෙමාපියන්ගේ නම
  age             String
  weight          String?

  complaint       String         // රෝග ලක්ෂණ
  diagnosis       String         // දොස්තරගේ නිගමනය
  specialAdvice   String?        // විශේෂ උපදෙස්
  nextVisitDate   DateTime?      // ඊළඟට එන්න ඕනේ දවස

  prescriptions   Prescription[] // ලබාදෙන බෙහෙත් ලැයිස්තුව
  createdAt       DateTime       @default(now())
}

model Prescription {
  id              String        @id @default(uuid())
  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id])

  drugName        String
  dosage          String
  frequency       String        // OD/BD/TDS
}

model AuditLog {
  id        String   @id @default(uuid())
  userEmail String?
  action    String   // LOGIN, LOGOUT, CREATE_DOCTOR, etc.
  type      String   // INFO, CRITICAL
  target    String?  // කොහේ action කළාද
  status    String   // Success, Failed
  ipAddress String?
  createdAt DateTime @default(now())
}